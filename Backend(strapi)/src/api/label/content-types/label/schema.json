{
  "kind": "collectionType",
  "collectionName": "labels",
  "info": {
    "singularName": "label",
    "pluralName": "labels",
    "displayName": "Label",
    "description": "Étiquettes pour catégoriser les cartes"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "color": {
      "type": "string",
      "required": true,
      "default": "#808080"
    },
    "cards": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::card.card",
      "mappedBy": "labels"
    }
  }
}
