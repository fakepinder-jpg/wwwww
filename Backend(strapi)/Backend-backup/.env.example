# Copie ce fichier et renomme le en .env
# Genere des nouvelles cles secretes avec : openssl rand -base64 16

# Serveur
HOST=0.0.0.0
PORT=1337

# Cles secretes Strapi (a changer en production !)
APP_KEYS=cle1,cle2,cle3,cle4
API_TOKEN_SALT=ton_salt_ici
ADMIN_JWT_SECRET=ton_secret_admin_ici
TRANSFER_TOKEN_SALT=ton_transfer_salt_ici
ENCRYPTION_KEY=ta_cle_encryption_ici

# Base de donnees (SQLite par defaut)
DATABASE_CLIENT=sqlite
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_SSL=false
DATABASE_FILENAME=.tmp/data.db

# Secret JWT pour les users
JWT_SECRET=ton_jwt_secret_ici
